    "validate:staging-bie": "node scripts/staging-bie-validate.mjs",
    "validate:largo-stress": "node --import tsx scripts/largo-stress-run.mjs",
    "validate:largo-stress-2": "LARGO_STRESS_BANK=2 node --import tsx scripts/largo-stress-run.mjs",
    "validate:largo-stress-3": "LARGO_STRESS_BANK=3 node --import tsx scripts/largo-stress-run.mjs",
    "validate:largo-stress-all": "LARGO_STRESS_BANK=all node --import tsx scripts/largo-stress-run.mjs",
    "validate:largo-stress-4": "LARGO_STRESS_BANK=4 node --import tsx scripts/largo-stress-run.mjs",
    "validate:largo-stress-live-all": "LARGO_STRESS_LIVE=1 LARGO_STRESS_BANK=all node --import tsx scripts/largo-stress-run.mjs",
    "validate:largo-stress-shape": "node --import tsx scripts/largo-stress-shape.mjs",
    "eval:bie": "node scripts/bie-eval/run.mjs",
    "eval:bie:score-test": "node --test scripts/bie-eval/lib/scoring.test.mjs",
    "validate:staging-playbook": "node scripts/validate-staging-playbook.mjs",
    "playbook:evidence-report": "node --import tsx scripts/playbook-evidence-report.mjs",
    "analyze:track-record-staging": "node --import tsx scripts/analyze-track-record-staging.mjs",
    "playbook:param-sweep": "node scripts/playbook-param-sweep.mjs",
    "validate:staging-desk-live": "node scripts/validate-staging-desk-live.mjs",
    "validate:staging-vector-e2e": "node scripts/vector-e2e-audit.mjs --base=https://staging.blackouttrades.com",
    "validate:latency-compare": "node scripts/compare-latency-envs.mjs",
    "validate:data-parity": "node scripts/staging-prod-data-parity.mjs",
    "validate:largo-latency": "node scripts/largo-latency-compare.mjs",
    "validate:latency-burst": "node scripts/latency-burst-audit.mjs",
    "validate:deploy-wait": "node scripts/gha-wait-deploy.mjs",
    "validate:rth-open": "node scripts/rth-open-check.mjs",
    "validate:rth-sweep": "node scripts/rth-comprehensive-sweep.mjs",
    "validate:exhaustive": "node scripts/exhaustive-platform-audit.mjs",
    "validate:spot-check": "node scripts/continuous-spot-check.mjs --once",
    "validate:spot-check:loop": "node scripts/continuous-spot-check.mjs",
    "validate:gha-rth": "node scripts/gha-rth-audit.mjs",
    "validate:gha-smoke": "node scripts/gha-http-smoke.mjs",
    "validate:cron": "node scripts/cron-audit-query.mjs",
    "railway:provision": "node scripts/railway-ops-provision.mjs",
    "railway:audit-apply": "node scripts/railway-audit-apply.mjs",
    "railway:legacy-cron-cleanup": "node scripts/railway-legacy-cron-cleanup.mjs",
    "validate:railway-crons": "node scripts/validate-railway-cron-manifest.mjs",
    "validate:spx-bie": "node --import tsx --experimental-test-module-mocks scripts/audit/spx-bie-consistency-validator.mjs",
    "validate:spx-rth": "node scripts/spx-rth-all-day-audit.mjs",
    "validate:spx-e2e": "node scripts/spx-dashboard-e2e-audit.mjs",
    "validate:vector-e2e": "node scripts/vector-e2e-audit.mjs",
    "validate:vector-rth": "node scripts/vector-rth-minute-audit.mjs --wait-open",
    "validate:member-dashboard": "node scripts/member-dashboard-live-check.mjs",
    "validate:site-latency": "node scripts/site-latency-audit.mjs",
    "validate:spx-bootstrap-profile": "node scripts/spx-bootstrap-cold-profile.mjs",
    "validate:grid-rth": "node scripts/grid-rth-all-day-audit.mjs",
    "validate:grid-e2e": "node scripts/grid-zerodte-e2e-audit.mjs",
    "validate:ios-config": "node apps/blackout-ios/scripts/validate-config.mjs",
    "validate:ios-mobile-desk": "node scripts/validate-ios-mobile-desk.mjs",
    "validate:ios-ui": "node scripts/validate-ios-mobile-desk.mjs",
    "probe:ios-ui": "node scripts/ios-ui-screenshot-probe.mjs",
    "test:ios-ui-e2e": "node scripts/ios-native-ui-e2e.mjs",
    "validate:zerodte-logic": "node scripts/zerodte-logic-audit.mjs",
    "validate:zerodte-integration": "node scripts/zerodte-integration-audit.mjs",
    "validate:zerodte-bie": "node scripts/audit/zerodte-bie-consistency-validator.mjs",
    "validate:api-auth": "node scripts/verify-api-auth-guards.mjs",
    "audit:deep-security": "node scripts/audit/deep-security-audit.mjs",
    "audit:deep-security:phase2": "node scripts/audit/deep-security-audit-phase2.mjs",
    "audit:deep-security:all": "node scripts/audit/deep-security-audit.mjs && node scripts/audit/deep-security-audit-phase2.mjs",
    "audit:premium-security": "node scripts/audit/premium-security-audit.mjs",
    "validate:railway-cron-schedules": "node scripts/railway-cron-schedule-audit.mjs",
    "ops:collect": "node scripts/ops-collect-action-items.mjs",
    "ops:collect:staging": "node scripts/ops-collect-staging.mjs",
    "ops:dispatch": "node scripts/ops-dispatch-agent.mjs",
    "docs:playbook": "node scripts/generate-spx-playbook-docx.mjs",
    "probe:docs": "node scripts/analyze-api-usage.mjs && node scripts/probe-docs-endpoints.mjs",
    "probe:helix-apis": "node scripts/helix-live-api-survey.mjs",
    "validate:helix-ui": "node scripts/helix-ui-audit.mjs",
    "analyze:api": "node scripts/analyze-api-usage.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@clerk/nextjs": "^7.5.17",
    "@clerk/types": "^4.101.25",
    "@sentry/nextjs": "^10.65.0",
    "@tanstack/react-virtual": "^3.14.6",
    "@types/web-push": "^3.6.4",
    "@whop/sdk": "0.0.40",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "ioredis": "5.11.1",
    "jose": "^5.10.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.395.0",
    "next": "^15.5.19",
    "pg": "8.22.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "sharp": "^0.35.3",
    "svix": "^1.45.1",
    "swr": "^2.4.2",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10",
    "docx": "^9.7.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "playwright": "^1.61.1",
    "postcss": "^8.5.18",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
