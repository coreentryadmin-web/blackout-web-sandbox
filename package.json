{
  "name": "blackout-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "docker:build": "docker build -f deploy/Dockerfile -t blackout-web:local .",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "lint:brand": "node scripts/check-brand.mjs",
    "lint:vendor": "node scripts/check-vendor-surfaces.mjs",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "PLAYBOOK_VERDICT_GUARD_ASSERT=1 node --import tsx --experimental-test-module-mocks --test \"src/**/*.test.ts\"",
    "validate:deploy": "node scripts/validate-deploy.mjs",
    "validate:vector-push-gate": "node scripts/vector-staging-e2e.mjs",
    "validate:vector-hardcore": "node scripts/vector-hardcore-e2e.mjs",
    "validate:staging": "node scripts/staging-validate.mjs",
    "validate:staging-rth": "node scripts/staging-rth-check.mjs",
    "validate:staging-live": "node scripts/staging-live-check.mjs",
    "validate:staging-cto": "node scripts/staging-cto-audit.mjs",
    "validate:staging-homepage": "node scripts/staging-homepage-profile.mjs",
    "validate:staging-site-e2e": "node scripts/staging-site-e2e.mjs",
    "capture:marketing-modules": "node scripts/capture-marketing-module-shots.mjs",
