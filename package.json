{
  "name": "blackout-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "lint:brand": "node scripts/check-brand.mjs",
    "lint:vendor": "node scripts/check-vendor-surfaces.mjs",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "validate:deploy": "node scripts/validate-deploy.mjs",
    "docs:playbook": "node scripts/generate-spx-playbook-docx.mjs",
    "probe:docs": "node scripts/analyze-api-usage.mjs && node scripts/probe-docs-endpoints.mjs",
    "probe:docs:uw": "node scripts/analyze-api-usage.mjs && node scripts/probe-docs-endpoints.mjs --uw-only",
    "analyze:api": "node scripts/analyze-api-usage.mjs",
    "nighthawk:run": "npx tsx scripts/nighthawk-worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@clerk/nextjs": "^7.5.8",
    "@clerk/types": "^4.101.25",
    "@sentry/nextjs": "^10.62.0",
    "@types/web-push": "^3.6.4",
    "@whop/sdk": "0.0.40",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "ioredis": "5.11.1",
    "lucide-react": "^0.395.0",
    "next": "^15.5.19",
    "pg": "8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "sharp": "^0.35.1",
    "svix": "^1.45.1",
    "swr": "^2.2.5",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10",
    "docx": "^9.7.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "postcss": "^8.5.10",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
