# BlackOut Production — AWS Secrets Manager merge template
# Copy to production.env (gitignored), fill in values, then run:
#   node scripts/merge-app-secret.mjs --secret-name blackout-production/app/env --env-file ./production.env --dry-run
# Remove --dry-run to apply.
#
# The 9 Terraform-managed keys below are already in the secret (auto-populated by infra):
#   DATABASE_URL, REDIS_URL, PORT, HOSTNAME, NODE_ENV, REPLICA_COUNT,
#   CRON_SECRET, PGBOUNCER_DEFAULT_POOL_SIZE, PG_POOL_MAX
# Only add keys that Terraform does NOT manage.

# ─── CRITICAL: Auth ────────────────────────────────────────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Production is the PRIMARY Clerk domain (not satellite).
# NEXT_PUBLIC_CLERK_IS_SATELLITE=false is set at Docker build time, not here.

# ─── CRITICAL: Database ───────────────────────────────────────────
PG_STATEMENT_TIMEOUT_MS=30000

# ─── HIGH: API Keys ───────────────────────────────────────────────
UW_API_KEY=
POLYGON_API_KEY=
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# ─── HIGH: Whop Billing ───────────────────────────────────────────
WHOP_COMPANY_ID=
WHOP_FREE_PLAN_ID=
WHOP_PRO_PLAN_ID=
WHOP_PREMIUM_PLAN_ID=
WHOP_ELITE_PLAN_ID=
WHOP_PREMIUM_PRODUCT_IDS=
WHOP_PRO_PRODUCT_IDS=
WHOP_ELITE_PRODUCT_IDS=

# ─── HIGH: Clerk admin emails ────────────────────────────────────
ADMIN_EMAILS=coreentryadmin@gmail.com

# ─── MEDIUM: Discord / Ops ───────────────────────────────────────
DISCORD_OPS_WEBHOOK_URL=
DISCORD_TRADE_WEBHOOK_URL=

# ─── MEDIUM: Push notifications (VAPID) ──────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── MEDIUM: Cloudflare ──────────────────────────────────────────
CF_ZONE_ID=
CF_API_TOKEN=

# ─── MEDIUM: Site identity ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://blackouttrades.com

# ─── MEDIUM: Cron config ─────────────────────────────────────────
CRON_TARGET_BASE_URL=https://blackouttrades.com

# ─── OPTIONAL: Search / AI ───────────────────────────────────────
# BRAVE_SEARCH_API_KEY=
# PERPLEXITY_API_KEY=
# INTEL_URL=

# ─── OPTIONAL: Sentry ────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=

# ─── Worker flags (set via ECS container_environment, not secrets) ─
# PROCESS_ROLE=web          (Terraform sets this)
# DATA_SOCKETS_ENABLED=0    (Terraform sets this for web; 1 for market worker)
# EAGER_DATA_SOCKETS=1      (market worker only)
